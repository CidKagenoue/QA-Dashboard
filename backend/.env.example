# Voorbeeldconfiguratie voor de backend.
# Kopieer naar `.env` en vul echte waarden in. `.env` staat in .gitignore
# en mag NOOIT met echte secrets gecommit worden.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/qa_login_backend?schema=public"

# --- JWT ---
# Minimaal 32 tekens, willekeurig. Niet de standaardwaarde laten staan.
JWT_SECRET="vervang-door-een-willekeurige-string-van-minstens-32-tekens"
JWT_REFRESH_SECRET="vervang-door-een-andere-willekeurige-string-van-32-tekens"
JWT_ISSUER="qa-login-backend"
JWT_AUDIENCE="qa-dashboard"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Bootstrap-adminaccount ---
# Wordt eenmalig aangemaakt als er nog geen admin met dit e-mailadres bestaat.
# Het wachtwoord moet voldoen aan het wachtwoordbeleid (min. 10 tekens, met
# hoofdletter, kleine letter, cijfer en speciaal teken). Gebruik een geldig
# e-mailadres dat je controleert, zodat wachtwoord-reset blijft werken.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="ChangeMe-Strong!23"

# --- Frontend ---
FRONTEND_URL="http://localhost:3000"
PUBLIC_FRONTEND_URL="http://localhost:3000"

# --- SMTP (e-mail) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@qa-dashboard.local"
SMTP_IGNORE_TLS_ERRORS="false"
