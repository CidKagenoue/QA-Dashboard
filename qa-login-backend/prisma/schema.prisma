
generator client {
  provider = "prisma-client-js"
  version = "6"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  password             String
  name                 String?
  isAdmin              Boolean               @default(false) @map("is_admin")
  basisAccess          Boolean               @default(false) @map("basis_access")
  whsToursAccess       Boolean               @default(false) @map("whs_tours_access")
  ovaAccess            Boolean               @default(false) @map("ova_access")
  japGppAccess         Boolean               @default(false) @map("jap_gpp_access")
  maintenanceInspectionsAccess Boolean       @default(false) @map("maintenance_inspections_access")
  // Notification preferences for modules
  notifyWhsTours       Boolean               @default(true)
  notifyOva            Boolean               @default(true)
  notifyJapGpp         Boolean               @default(true)
  notifyMaintenance    Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  refreshTokenSessions RefreshTokenSession[]
  passwordResetTokens  PasswordResetToken[]
  createdOvaTickets    OvaTicket[]           @relation("OvaTicketCreatedBy")
  editedOvaTickets     OvaTicket[]           @relation("OvaTicketLastEditedBy")
  closedOvaTickets     OvaTicket[]           @relation("OvaTicketClosedBy")
  assignedOvaActions   OvaFollowUpAction[]   @relation("OvaFollowUpActionInternalAssignee")

  departmentLeaders DepartmentLeader[]
  departments       UserDepartment[]
  profileImage      String? // base64 string van profielfoto

  notificationSettings NotificationSetting[]
  notifications Notification[]

  @@map("users")
}

model RefreshTokenSession {
  id        String    @id
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "refresh_token_sessions_user_id_idx")
  @@map("refresh_token_sessions")
}

model Department {
  id Int @id @default(autoincrement())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaders   DepartmentLeader[]
  members   UserDepartment[]
}

model DepartmentLeader {
  id           Int        @id @default(autoincrement())
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId Int
  user         User       @relation(fields: [userId], references: [id])
  userId       Int
}

model UserDepartment {
  userId       Int
  departmentId Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    Int       @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@map("password_reset_tokens")
}

model OvaTicket {
  id                  Int      @id @default(autoincrement())
  status              String   @default("incomplete")
  currentStep         Int      @default(1) @map("current_step")
  findingDate         DateTime? @map("finding_date")
  ovaType             String?  @map("ova_type")
  reasons             String[] @default([])
  otherReason         String?  @map("other_reason")
  incidentDescription String?  @map("incident_description")
  causeAnalysisMethod String?  @map("cause_analysis_method")
  causeAnalysisNotes  String?  @map("cause_analysis_notes")
  followUpActions     String?  @map("follow_up_actions")
  effectivenessDate   DateTime? @map("effectiveness_date")
  effectivenessNotes  String?  @map("effectiveness_notes")
  closureNotes        String?  @map("closure_notes")
  closedAt            DateTime? @map("closed_at")
  closedById          Int?      @map("closed_by_id")
  createdById         Int      @map("created_by_id")
  lastEditedById      Int      @map("last_edited_by_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  createdBy           User     @relation("OvaTicketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lastEditedBy        User     @relation("OvaTicketLastEditedBy", fields: [lastEditedById], references: [id], onDelete: Restrict)
  closedBy            User?    @relation("OvaTicketClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  actions             OvaFollowUpAction[]

  @@index([createdById], map: "ova_tickets_created_by_id_idx")
  @@index([lastEditedById], map: "ova_tickets_last_edited_by_id_idx")
  @@index([closedById], map: "ova_tickets_closed_by_id_idx")
  @@map("ova_tickets")
}

model OvaExternalContact {
  id        Int                 @id @default(autoincrement())
  firstName String              @map("first_name")
  lastName  String              @map("last_name")
  email     String?
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  actions   OvaFollowUpAction[]

  @@index([lastName, firstName], map: "ova_external_contacts_name_idx")
  @@index([email], map: "ova_external_contacts_email_idx")
  @@map("ova_external_contacts")
}

model OvaFollowUpAction {
  id                Int                 @id @default(autoincrement())
  ticketId          Int                 @map("ticket_id")
  type              String
  description       String
  dueDate           DateTime            @map("due_date")
  status            String              @default("nok")
  assigneeType      String              @map("assignee_type")
  internalAssigneeId Int?               @map("internal_assignee_id")
  externalContactId Int?                @map("external_contact_id")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  ticket            OvaTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  internalAssignee  User?               @relation("OvaFollowUpActionInternalAssignee", fields: [internalAssigneeId], references: [id], onDelete: SetNull)
  externalContact   OvaExternalContact? @relation(fields: [externalContactId], references: [id], onDelete: SetNull)

  @@index([ticketId], map: "ova_follow_up_actions_ticket_id_idx")
  @@index([internalAssigneeId], map: "ova_follow_up_actions_internal_assignee_id_idx")
  @@index([externalContactId], map: "ova_follow_up_actions_external_contact_id_idx")
  @@map("ova_follow_up_actions")
}


model Branch {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  locations Location[]
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  branchId  Int?
  branch    Branch? @relation(fields: [branchId], references: [id])
}

model MaintenanceInspection {
  id                  Int      @id @default(autoincrement())
  equipment           String
  inspectionType      String
  inspectionInstitution String
  contactInfo         String?
  locationIds         Int[]    @default([])
  frequency           String
  selfContact         Boolean  @default(false)
  lastInspectionDate  DateTime?
  dueDate             DateTime
  status              String?  @default("Open")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("maintenance_inspections")
}

// This is your Prisma schema file,
// NotificationSetting: per-user, per-type notificatievoorkeuren

enum NotificationModule {
  WHS_TOURS
  OVA
  JAP
  MAINTENANCE

  }

  enum NotificationType {
    OVA_TICKET_CREATED
    OVA_ACTION_ASSIGNED
    OVA_ACTION_REASSIGNED
    OVA_TICKET_STATUS_CHANGED
    ACCOUNT_CREATED
    ACCOUNT_ACCESS_CHANGED
    ACCOUNT_DELETED
    PASSWORD_CHANGED
    WHS_NEW_TASK
    WHS_COMMENT
    WHS_NEW_REPORT
    OVA_DEADLINE
    OVA_NEW_ACTION
    OVA_1
    OVA_2
    OVA_3
    JAP_NEW
    JAP_COMMENT
    JAP_STATUS_CHANGE
    MAINTENANCE_NEW
    MAINTENANCE_DUE
    MAINTENANCE_STATUS_CHANGE
  }

model NotificationSetting {
  id               Int               @id @default(autoincrement())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  module           NotificationModule
  type             NotificationType
  enabled          Boolean           @default(true)
  email            Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([userId, type])
}
// Stores actual notifications for badge/count and notification list
model Notification {
  id              Int              @id @default(autoincrement())
  recipientUserId Int              @map("recipient_user_id")
  type            NotificationType
  title           String
  body            String
  metadata        Json?
  isRead          Boolean          @default(false) @map("is_read")
  readAt          DateTime?        @map("read_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  recipient       User             @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, isRead], map: "notifications_recipient_is_read_idx")
  @@index([createdAt], map: "notifications_created_at_idx")
  @@map("notifications")
}
// learn more about it in the docs: https://pris.ly/d/prisma-schema
